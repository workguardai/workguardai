# WorkGuard AI — environment template.
# Copy to `.env.local` and fill in real values. `lib/env.ts` validates these
# at startup and the app will refuse to boot if any are missing/invalid.

# --- Database (PostgreSQL) ---
# Supabase connection string (use the pooled connection for the app runtime).
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# --- Supabase Auth ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Security ---
# Used for signing/verifying app-issued tokens. Min 16 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret"

# --- AI (Google Gemini) ---
GEMINI_API_KEY="your-gemini-api-key"

# --- File storage ---
# Storage bucket name for uploaded drawings.
UPLOAD_BUCKET="drawings"

# --- Drawing parser strategy ---
# gemini_direct = POC: raw file -> Gemini multimodal.
# dxf_geometry  = recommended: DWG -> DXF -> geometry -> Gemini reasoning.
DRAWING_PARSER_STRATEGY="gemini_direct"
